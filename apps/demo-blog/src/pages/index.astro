---
import {
  BTreeOps,
  BranchPredictor,
  CFGBuilder,
  CacheSimulator,
  CpuPipeline,
  GraphTraversal,
  HashCollision,
  InodeTree,
  Lexer,
  Parser,
  ProcessScheduler,
  RegisterAllocator,
  SortRace,
  StorageComparison,
  SyscallTrace,
  TLBWalk,
  VirtualMemory,
} from "@vislab/react";
import Layout from "../layouts/vislab-page.astro";
---

<Layout title="VisLab demos">
  <p class="lead">
    All 17 registry widgets — chrome variants: <strong>article</strong>,
    <strong>diagram</strong>, <strong>toolbar</strong>, <strong>terminal</strong>.
  </p>

  <div class="grid">
    <section class="cell cell--wide">
      <h2 class="demo-heading">Storage</h2>
      <StorageComparison client:visible />
    </section>
    <section class="cell">
      <h2 class="demo-heading">CPU pipeline</h2>
      <CpuPipeline client:visible autoPlay={true} />
    </section>
    <section class="cell">
      <h2 class="demo-heading">Branch predictor</h2>
      <BranchPredictor client:visible />
    </section>
    <section class="cell">
      <h2 class="demo-heading">TLB walk</h2>
      <TLBWalk client:visible />
    </section>
    <section class="cell cell--wide">
      <h2 class="demo-heading">Cache</h2>
      <CacheSimulator client:visible />
    </section>
    <section class="cell">
      <h2 class="demo-heading">Process scheduler</h2>
      <ProcessScheduler client:visible />
    </section>
    <section class="cell">
      <h2 class="demo-heading">Virtual memory</h2>
      <VirtualMemory client:visible />
    </section>
    <section class="cell">
      <h2 class="demo-heading">Syscall trace</h2>
      <SyscallTrace client:visible />
    </section>
    <section class="cell">
      <h2 class="demo-heading">Inode tree</h2>
      <InodeTree client:visible />
    </section>
    <section class="cell">
      <h2 class="demo-heading">Sort race</h2>
      <SortRace client:visible />
    </section>
    <section class="cell">
      <h2 class="demo-heading">B-tree ops</h2>
      <BTreeOps client:visible />
    </section>
    <section class="cell">
      <h2 class="demo-heading">Graph traversal</h2>
      <GraphTraversal client:visible />
    </section>
    <section class="cell">
      <h2 class="demo-heading">Hash collisions</h2>
      <HashCollision client:visible />
    </section>
    <section class="cell">
      <h2 class="demo-heading">Lexer</h2>
      <Lexer client:visible />
    </section>
    <section class="cell">
      <h2 class="demo-heading">Parser</h2>
      <Parser client:visible />
    </section>
    <section class="cell">
      <h2 class="demo-heading">CFG builder</h2>
      <CFGBuilder client:visible />
    </section>
    <section class="cell">
      <h2 class="demo-heading">Register allocator</h2>
      <RegisterAllocator client:visible />
    </section>
  </div>
</Layout>

<style>
  .lead {
    color: #64748b;
    margin-bottom: 1.5rem;
    max-width: 48rem;
    line-height: 1.55;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
    align-items: start;
  }
  .cell--wide {
    grid-column: 1 / -1;
  }
  .demo-heading {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: #94a3b8;
    margin: 0 0 0.5rem 0;
  }
</style>