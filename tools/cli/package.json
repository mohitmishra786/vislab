{
  "name": "@vislab/cli",
  "version": "0.2.0",
  "description": "CLI to build, preview, and scaffold VisLab visualization embeds",
  "keywords": ["vislab", "cli", "embed", "systems-visualization"],
  "bin": {
    "vislab": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vislab/registry": "workspace:*",
    "commander": "^11.1.0",
    "zx": "^8.8.5",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mohitmishra786/vislab.git",
    "directory": "tools/cli"
  },
  "license": "MIT"
}
