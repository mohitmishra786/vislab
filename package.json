{
  "name": "vislab-monorepo",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome check .",
    "format": "biome check --write . && prettier --write \"**/*.{ts,tsx,md}\"",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm run build && changeset publish",
    "check:bundle-size": "node scripts/check-bundle-size.mjs",
    "docs:widgets": "node scripts/generate-widget-docs.mjs",
    "sri": "node scripts/compute-sri.mjs",
    "media:capture": "node scripts/capture-readme-media.mjs",
    "media:gif": "node scripts/capture-readme-gif.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.31.1",
    "@types/node": "^20.19.43",
    "prettier": "^3.9.6",
    "turbo": "^2.10.5",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"],
    "overrides": {
      "@babel/core": ">=7.29.6",
      "basic-ftp": ">=5.3.1",
      "devalue": ">=5.8.1",
      "esbuild": ">=0.28.1",
      "ip-address": ">=10.1.1",
      "js-yaml": "4.3.0",
      "postcss": ">=8.5.10",
      "vitest": ">=3.2.7",
      "ws": ">=8.21.0",
      "vite": ">=7.3.2"
    }
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
