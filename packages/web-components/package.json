{
  "name": "@vislab/web-components",
  "version": "0.0.0",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm,iife --global-name VisLabEmbeds --dts",
    "dev": "tsup src/index.ts --format cjs,esm,iife --global-name VisLabEmbeds --dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@vislab/components": "workspace:*",
    "@vislab/registry": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mohitmishra786/vislab.git",
    "directory": "packages/web-components"
  },
  "license": "MIT"
}
