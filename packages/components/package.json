{
  "name": "@vislab/components",
  "version": "0.0.0",
  "description": "17 systems engineering canvas widgets (CPU, cache, OS, compiler, algorithms) for VisLab",
  "keywords": [
    "vislab",
    "cpu-pipeline",
    "cache-simulator",
    "process-scheduler",
    "systems-programming",
    "education",
    "canvas",
    "technical-writing"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./widgets/*": {
      "types": "./dist/widgets/*.d.ts",
      "import": "./dist/widgets/*.mjs",
      "require": "./dist/widgets/*.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": ["./dist/chunk-*.js", "./dist/chunk-*.mjs"],
  "files": ["dist"],
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "dev": "tsup --config tsup.config.ts --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "happy-dom": "^20.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.2.7"
  },
  "dependencies": {
    "@vislab/core": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mohitmishra786/vislab.git",
    "directory": "packages/components"
  },
  "license": "MIT"
}
